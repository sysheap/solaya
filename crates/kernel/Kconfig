menu "Kernel subsystems"

config SMP
	bool "Symmetric multiprocessing"
	default y
	help
	  Enables multi-hart scheduling. When disabled, only hart 0 runs.

config SMP_MAX_CPUS
	int "Maximum CPUs"
	depends on SMP
	range 1 64
	default 8

config NET
	bool "Network stack"
	default y
	help
	  Enables the UDP/TCP stack and virtio-net driver.

config FB
	bool "Framebuffer (bochs-display)"
	default n
	help
	  Enables framebuffer output. With FB off, all kernel output goes
	  through the UART.

endmenu

menu "Logging and debugging"

config LOG_DEFAULT_LEVEL
	int "Default log level (0=off, 1=warn, 2=info, 3=debug, 4=trace)"
	range 0 4
	default 2

config LOG_MODULES
	string "Extra modules to force-enable debug logging (comma-separated)"
	default ""
	help
	  Comma-separated list of module paths whose debug! calls should be
	  printed regardless of the default log level, e.g.
	  "kernel::processes::scheduler,kernel::net::tcp".

config DEBUG_ASSERTIONS
	bool "Runtime debug assertions"
	default y
	help
	  Enables debug_assert! and overflow checks in release builds.

endmenu
