# Solaya Kernel Configuration
#
# Root Kconfig. Today only the target architecture is configurable; other
# knobs were removed because no Rust code consumed them. Run
# `cmake --build build --target menuconfig` to configure interactively, or
# copy a defconfig from configs/ as a starting point.

mainmenu "Solaya Kernel Configuration"

choice
	prompt "Target architecture"
	default ARCH_RISCV64
	help
	  Select the target architecture. Only RISC-V 64 is implemented
	  today.

config ARCH_RISCV64
	bool "RISC-V 64-bit"

endchoice

config ARCH
	string
	default "riscv64" if ARCH_RISCV64
