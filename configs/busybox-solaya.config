# Minimal busybox config for Solaya — provides `init` only.
#
# Rationale: the user directive is "dash + GNU coreutils" for user
# commands.  Letting busybox supply its own `echo`, `ls`, etc. would
# put them ahead of GNU on PATH and break tests that assert GNU output.
# So we disable every applet except init plus the shutdown-path
# helpers that busybox-init invokes internally (poweroff/reboot/halt).
#
# To regenerate: run `make menuconfig` inside the buildroot output
# tree's busybox build dir, save, then copy back.  Most entries below
# are explicit `is not set` lines so `make oldconfig` stays silent.

CONFIG_INIT=y
CONFIG_FEATURE_USE_INITTAB=y
CONFIG_FEATURE_INIT_SCTTY=y
CONFIG_FEATURE_INIT_SYSLOG=y
CONFIG_FEATURE_EXTRA_QUIET=y
CONFIG_HALT=y
CONFIG_POWEROFF=y
CONFIG_REBOOT=y

# Everything else: off.  Listing the common ones explicitly so buildroot's
# oldconfig doesn't prompt; unlisted applets default-off.
# CONFIG_ASH is not set
# CONFIG_HUSH is not set
# CONFIG_SH_IS_ASH is not set
# CONFIG_SH_IS_HUSH is not set
# CONFIG_BASH_IS_ASH is not set
# CONFIG_BASH_IS_HUSH is not set
# CONFIG_CAT is not set
# CONFIG_ECHO is not set
# CONFIG_LS is not set
# CONFIG_CP is not set
# CONFIG_MV is not set
# CONFIG_RM is not set
# CONFIG_MKDIR is not set
# CONFIG_RMDIR is not set
# CONFIG_TOUCH is not set
# CONFIG_PWD is not set
# CONFIG_TRUE is not set
# CONFIG_FALSE is not set
# CONFIG_SLEEP is not set
# CONFIG_DATE is not set
# CONFIG_CHMOD is not set
# CONFIG_CHOWN is not set
# CONFIG_HEAD is not set
# CONFIG_TAIL is not set
# CONFIG_GREP is not set
# CONFIG_SED is not set
# CONFIG_AWK is not set
# CONFIG_TAR is not set
# CONFIG_GZIP is not set
# CONFIG_MOUNT is not set
# CONFIG_UMOUNT is not set
# CONFIG_DHCP is not set
# CONFIG_UDHCPC is not set
# CONFIG_IP is not set
# CONFIG_IFCONFIG is not set
