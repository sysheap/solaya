# Buildroot defconfig for the Solaya userspace.  Expanded from
# solaya_riscv64_buildroot_defconfig.in via CMake's configure_file();
# the @PLACEHOLDERS@ resolve to absolute paths at configure time.
#
# Outputs rootfs.cpio (uncompressed newc) at
# ${_br_out}/images/rootfs.cpio — Solaya loads it via QEMU -initrd.

# --- Target architecture (RISC-V 64-bit, rv64g to match Bootlin toolchain)
# Bootlin's prebuilt riscv64 toolchain targets the "general" ISA profile
# (IMAFD — no compressed 'C').  Binaries compiled for G run fine on our
# kernel's GC target since GC is a superset; the tradeoff is slightly
# larger userspace binaries than a C-enabled build.
BR2_riscv=y
BR2_RISCV_64=y
BR2_RISCV_ABI_LP64D=y
BR2_riscv_g=y

# --- Toolchain -----------------------------------------------------------
# Buildroot's toolchain infrastructure has no clang/LLVM path — every
# external-toolchain option hard-requires GCC wrappers (grep 'clang' in
# toolchain/ turns up zero matches as of 2025.02.x).  Rather than make
# buildroot build a second GCC from source (BR2_TOOLCHAIN_BUILDROOT,
# ~20 min cold), grab Bootlin's pre-built riscv64-lp64d musl GCC — ~80 MB
# download, ready to use, ABI-compatible with our LLVM-built Rust binaries
# (both link against musl 1.2.x, same dynamic linker path).
BR2_TOOLCHAIN_EXTERNAL=y
BR2_TOOLCHAIN_EXTERNAL_BOOTLIN=y
BR2_TOOLCHAIN_EXTERNAL_BOOTLIN_RISCV64_LP64D_MUSL_STABLE=y

# --- Init system: busybox (init applet only) -----------------------------
BR2_INIT_BUSYBOX=y
BR2_PACKAGE_BUSYBOX=y
# Use our minimal busybox config — only CONFIG_INIT plus the reboot/poweroff
# helpers busybox init invokes internally.  Keeps busybox from shadowing
# GNU coreutils on PATH.
BR2_PACKAGE_BUSYBOX_CONFIG="@SOLAYA_BUSYBOX_CONFIG@"
BR2_PACKAGE_BUSYBOX_CONFIG_FRAGMENT_FILES=""
# Do NOT enable busybox applets — our command set comes from dash + GNU
# coreutils below.

# --- Shell + coreutils ---------------------------------------------------
BR2_PACKAGE_DASH=y
BR2_PACKAGE_COREUTILS=y
# buildroot's default /bin/sh symlink points at busybox ash; the
# post-build script relinks it to /bin/dash (below).

# --- Skip networking packages; Solaya's Rust daemons cover dhcpd etc. ----
# BR2_PACKAGE_DHCPCD is not set
# BR2_PACKAGE_IPROUTE2 is not set

# --- Rootfs delivery: uncompressed cpio newc -----------------------------
BR2_TARGET_ROOTFS_CPIO=y
# BR2_TARGET_ROOTFS_CPIO_GZIP is not set
# BR2_TARGET_ROOTFS_TAR is not set
# BR2_TARGET_ROOTFS_EXT2 is not set

# --- Skip kernel + bootloader (Solaya IS the kernel) --------------------
# BR2_LINUX_KERNEL is not set
# BR2_TARGET_UBOOT is not set

# --- Overlay: inject Solaya Rust binaries + /etc skeleton at rootfs time -
BR2_ROOTFS_OVERLAY="@SOLAYA_BUILDROOT_OVERLAY_DIR@"
BR2_ROOTFS_POST_BUILD_SCRIPT="@SOLAYA_BUILDROOT_POST_BUILD_SCRIPT@"
